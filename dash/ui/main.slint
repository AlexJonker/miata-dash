import { HomePage } from "./pages/home.slint";
import { MusicPage } from "./pages/music.slint";
import { SettingsPage } from "./pages/settings.slint";
import { AndroidAutoPage } from "./pages/android_auto.slint";

component NavItem inherits Rectangle {
    in property <string> text;
    in property <bool> selected;

    callback clicked;

    height: 40px;
    background: root.selected ? #c20000 : transparent;
    border-radius: 6px;

    Text {
        text: root.text;
        color: root.selected ? #ffffff : #a0a0a0;
        font-size: 13px;
        font-weight: 500;
    }

    TouchArea {
        clicked => {
            root.clicked();
        }
    }
}

export component AppWindow inherits Window {
    title: "Rusty Dash";
    full-screen: true;

    background: #121212;

    in-out property <int> current-page: 0;

    in-out property <bool> is-playing: false;
    in-out property <bool> is-loop-enabled: false;
    in-out property <bool> is-shuffle-enabled: false;

    in-out property <string> track-title: "Title";
    in-out property <string> artist-name: "Artist";
    in-out property <string> album-name: "Album";

    callback play-pause();
    callback next-track();
    callback previous-track();
    callback toggle-loop();
    callback toggle-shuffle();

    callback shutdown();

    VerticalLayout {
        HorizontalLayout {
            NavItem {
                text: "Home";
                selected: root.current-page == 0;
                clicked => {
                    root.current-page = 0;
                }
            }

            NavItem {
                text: "Music";
                selected: root.current-page == 1;
                clicked => {
                    root.current-page = 1;
                }
            }

            NavItem {
                text: "Settings";
                selected: root.current-page == 2;
                clicked => {
                    root.current-page = 2;
                }
            }

            NavItem {
                text: "Android Auto";
                selected: root.current-page == 3;
                clicked => {
                    root.current-page = 3;
                }
            }
        }

        Rectangle {
            if root.current-page == 0: HomePage { }

            if root.current-page == 1: MusicPage {
                is-playing: root.is-playing;
                is-loop-enabled: root.is-loop-enabled;
                is-shuffle-enabled: root.is-shuffle-enabled;

                track-title: root.track-title;
                artist-name: root.artist-name;
                album-name: root.album-name;

                play-pause => {
                    root.play-pause();
                }
                next-track => {
                    root.next-track();
                }
                previous-track => {
                    root.previous-track();
                }
                toggle-loop => {
                    root.toggle-loop();
                }
                toggle-shuffle => {
                    root.toggle-shuffle();
                }
            }

            if root.current-page == 2: SettingsPage {
                shutdown => {
                    root.shutdown();
                }
            }

            if root.current-page == 3: AndroidAutoPage {
            }
        }
    }
}

FROM https://downloads.raspberrypi.org/raspios_lite_armhf_latest
TO image.img
PUMP 10000M

RUN apt-get update
# RUN apt-get upgrade -y

# xorg deps
RUN apt-get install -y --no-install-recommends \
    xserver-xorg-core \
    xserver-xorg \
    xinit \
    x11-xserver-utils \
    xauth \
    xfonts-base \
    xserver-xorg-video-fbdev \
    xserver-xorg-input-evdev \
    libx11-6 \
    libx11-dev \
    libxext6 \
    libxrandr2 \
    libxinerama1 \
    libxcursor1 \
    libxi6 \
    libxrender1 \
    libxfixes3 \
    libxdamage1 \
    libxcomposite1 \
    libgl1 \
    libegl1 \
    libxkbcommon-x11-0

# Build deps
RUN apt-get install rustup git -y --no-install-recommends

# Disable the setup tui
RUN systemctl disable cloud-config
RUN systemctl disable userconfig
RUN systemctl disable cloud-final

# Setup users
RUN sh -c '
# Rename the user pi
usermod -l car pi

# Rename the home directory
usermod -d /home/car -m car

# Rename the primary group
groupmod -n car pi

# Set passwords
echo "car:car" | chpasswd
echo "root:car" | chpasswd

# Add to sudo
# usermod -aG sudo car
'

# Install cargo
RUN rustup install stable

# Required for alsa
RUN sh -c '
cd /tmp
wget -q http://ftp.debian.org/debian/pool/main/a/alsa-lib/libasound2_1.2.8-1+b1_armhf.deb
wget -q http://ftp.debian.org/debian/pool/main/a/alsa-lib/libasound2-dev_1.2.8-1+b1_armhf.deb
dpkg -x libasound2_1.2.8-1+b1_armhf.deb extracted
dpkg -x libasound2-dev_1.2.8-1+b1_armhf.deb extracted-dev
cp -r extracted/usr/lib/arm-linux-gnueabihf/* /usr/lib/arm-linux-gnueabihf/
cp -r extracted-dev/usr/lib/arm-linux-gnueabihf/* /usr/lib/arm-linux-gnueabihf/
cp -r extracted-dev/usr/include/* /usr/include/
rm -rf extracted extracted-dev *.deb
'

# Build the dashboard
RUN sh -c '
export PKG_CONFIG_PATH=/usr/lib/arm-linux-gnueabihf/pkgconfig:$PKG_CONFIG_PATH
git clone https://github.com/alexjonker/dash
cd dash
cargo build --release
mv ./target/release/dash /usr/local/bin/dash
cd ..
rm -fr dash
'

# Move all files in src to the image.
INSTALL src/ /

# Clean up image 
RUN apt purge rustup git -y
RUN apt autoremove -y
RUN apt clean
RUN rm -rf /var/lib/apt/lists/*
RUN rm -rf ~/.cargo
RUN rm -fr ~/.rustup
RUN rm -rf /tmp/*
SHRINK
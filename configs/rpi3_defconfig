BR2_arm=y
BR2_cortex_a7=y
BR2_ARM_EABIHF=y

BR2_ARM_CPU_HAS_VFPV3=y
BR2_ARM_CPU_HAS_NEON=y

# Raspberry Pi firmware
BR2_PACKAGE_RPI_FIRMWARE=y
BR2_PACKAGE_RPI_FIRMWARE_INSTALL_DTBS=y
BR2_PACKAGE_RPI_FIRMWARE_INSTALL_DTB_OVERLAYS=y

# Filesystem images
BR2_TARGET_ROOTFS_EXT2=y
BR2_TARGET_ROOTFS_EXT2_4=y
BR2_TARGET_ROOTFS_RPI=y

# Linux kernel
BR2_LINUX_KERNEL=y
BR2_LINUX_KERNEL_CUSTOM_REPO_URL="https://github.com/raspberrypi/linux.git"
BR2_LINUX_KERNEL_CUSTOM_REPO_VERSION="rpi-6.6.y"  # Changed from rpi-6.12.y to a more stable branch
BR2_LINUX_KERNEL_DEFCONFIG="bcm2709"  # This is correct, Buildroot adds _defconfig automatically

# Add kernel modules
BR2_LINUX_KERNEL_INSTALL_TARGET=y

# U-Boot bootloader (optional but recommended)
BR2_TARGET_UBOOT=y
BR2_TARGET_UBOOT_BOARDNAME="rpi_2"
BR2_TARGET_UBOOT_CUSTOM_VERSION=y
BR2_TARGET_UBOOT_CUSTOM_VERSION_VALUE="2024.01"

# Boot script
BR2_PACKAGE_HOST_UBOOT_TOOLS=y
BR2_PACKAGE_UBOOT_TOOLS=y
BR2_PACKAGE_UBOOT_TOOLS_MKIMAGE=y

# Toolchain options
BR2_TOOLCHAIN_BUILDROOT=y
BR2_TOOLCHAIN_BUILDROOT_CXX=y

# System configuration
BR2_TARGET_GENERIC_HOSTNAME="car-thing"
BR2_TARGET_GENERIC_ISSUE="Welcome to Car Thing"
BR2_TARGET_GENERIC_GETTY_PORT="console"
BR2_TARGET_GENERIC_GETTY_BAUDRATE="115200"

# Required packages for Raspberry Pi
BR2_PACKAGE_ALSA_LIB=y
BR2_PACKAGE_ALSA_UTILS=y
BR2_PACKAGE_RPI_USERLAND=y  # For GPU acceleration